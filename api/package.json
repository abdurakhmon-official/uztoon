{
  "name": "uztoon-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && npm run barrels && tsc --project tsconfig.compile.json && npx tsc-alias --project tsconfig.compile.json",
    "barrels": "barrelsby --config .barrelsby.json",
    "start": "npm run barrels && cross-env STAGE=local nodemon --exec ts-node index.ts",
    "start:prod": "cross-env NODE_ENV=production STAGE=production node dist/index.js",
    "test": "jest",
    "render:build": "tsc -p tsconfig.json && tsc-alias",
    "render:start": "HOST=0.0.0.0 node -r tsconfig-paths/register dist/server.js",
    "typecheck": "yarn tsc -P .",
    "generate:types": "npm run barrels && npx ts-node --project tsconfig.compile.json -r tsconfig-paths/register generate-types.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
